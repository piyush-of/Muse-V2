# --- Database ---
# PostgreSQL connection string, e.g. from Supabase, Neon, Railway, or a local Postgres install.
DATABASE_URL="postgresql://user:password@localhost:5432/muse"

# --- Auth (NextAuth / Auth.js v5) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# --- Google Gemini (outfit reasoning + garment auto-tagging) ---
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# --- Default location for weather (used until a user grants browser geolocation) ---
# Defaults to Jaipur, India if unset.
DEFAULT_LAT="26.9124"
DEFAULT_LON="75.7873"

# --- Cloudinary (garment photo storage) ---
# Either set CLOUDINARY_URL, or the three CLOUD_NAME/API_KEY/API_SECRET vars below.
CLOUDINARY_URL=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
