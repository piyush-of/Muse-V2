datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String
  timezone     String        @default("UTC")
  createdAt    DateTime      @default(now())
  closetItems  ClosetItem[]
  wearEvents   WearEvent[]
  outfits      Outfit[]
  styleProfile StyleProfile?
}

model ClosetItem {
  id         Int         @id @default(autoincrement())
  userId     Int
  photoUrl   String
  category   String
  color      String
  season     String
  formality  String
  createdAt  DateTime    @default(now())
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  wearEvents WearEvent[]
}

model WearEvent {
  id           Int        @id @default(autoincrement())
  closetItemId Int
  userId       Int
  wornAt       DateTime   @default(now())
  outfitId     Int?
  closetItem   ClosetItem @relation(fields: [closetItemId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfit       Outfit?    @relation(fields: [outfitId], references: [id], onDelete: SetNull)
}

model Outfit {
  id              Int         @id @default(autoincrement())
  userId          Int
  date            String      // Format: YYYY-MM-DD
  itemIdsString   String      // Comma-separated ClosetItem IDs
  reasoning       String
  status          String      // "pending" | "accepted" | "rejected"
  rejectionReason String?
  createdAt       DateTime    @default(now())
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  wearEvents      WearEvent[]
}

model StyleProfile {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  traitsString    String   @default("{}")
  topColorsString String   @default("[]")
  lastComputedAt  DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
